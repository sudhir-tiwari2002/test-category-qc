# Copy to .env and edit. The CLI also accepts the same values as flags.

# CDP port that Chrome must be launched with: --remote-debugging-port=9333
# NOTE: 9222 (Chrome's documented default) is also adb's default forward target,
# so we use 9333 to avoid conflict on dev machines with Android tooling.
CDP_PORT=9333

# Optional: pin the test-category URL (otherwise pass --category-url at runtime
# or let the script use whatever tab is currently active in the attached Chrome).
CATEGORY_URL=

# Comma separated. Order matters: pass starts with the FIRST language.
LANGUAGES=en,hi

# Where the report goes
OUTPUT_DIR=./reports

# Soft cap; set to 0 for "all questions in the category".
MAX_QUESTIONS=0

# Slow down each action by N ms (helps when admin UI is laggy). 0 = native speed.
SLOW_MO_MS=0
