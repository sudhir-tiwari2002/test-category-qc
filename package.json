{
  "name": "test-category-qc",
  "version": "0.1.0",
  "private": true,
  "description": "Automated QC/sanity checks for PhysicsWallah admin test categories (Hindi + English).",
  "type": "module",
  "bin": {
    "qc": "./bin/qc"
  },
  "scripts": {
    "launch-chrome": "./scripts/launch-chrome.sh",
    "inspect": "tsx src/inspect.ts",
    "qc": "tsx src/index.ts",
    "setup": "./bin/qc setup",
    "doctor": "./bin/qc doctor",
    "all": "./bin/qc all",
    "typecheck": "tsc -p . --noEmit",
    "build": "tsc -p ."
  },
  "engines": {
    "node": ">=18.18"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^13.1.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "playwright": "^1.61.1",
    "tesseract.js": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
